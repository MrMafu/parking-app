// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum RateType {
  Hourly
  Daily
  Flat
}

enum ParkingAreaStatus {
  Open
  Closed
  Maintenance
}

enum TransactionStatus {
  Open
  AwaitingPayment
  Closed
  Cancelled
}

enum PaymentMethod {
  Qris
  Cash
}

enum PaymentStatus {
  Pending
  Completed
  Failed
}

model User {
  id           Int       @id @default(autoincrement())
  fullname     String
  username     String    @unique
  email        String    @unique
  password     String    @map("password")
  roleId       Int       @map("role_id")
  role         Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  activityLogs         ActivityLog[]
  attendedTransactions Transaction[] @relation("TransactionsAttendedBy")
  printedReceipts      Receipt[]     @relation("ReceiptsPrintedBy")
  processedRefunds     Refund[]      @relation("RefundsProcessedBy")

  @@index([roleId])
  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  rolePerms   RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePerms   RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  action    String
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("activity_logs")
}

model VehicleType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rates        Rate[]
  parkingAreas ParkingArea[]

  @@map("vehicle_types")
}

model Rate {
  id            Int         @id @default(autoincrement())
  name          String
  vehicleTypeId Int         @map("vehicle_type_id")
  vehicleType   VehicleType @relation(fields: [vehicleTypeId], references: [id], onDelete: Restrict)
  rateType      RateType    @map("rate_type")
  priceCents    Int         @map("price_cents")
  graceMinutes  Int         @default(0) @map("grace_minutes")
  // validTo must be after validFrom — enforced at application layer
  validFrom     DateTime    @map("valid_from")
  validTo       DateTime    @map("valid_to")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  transactions  Transaction[]

  @@index([vehicleTypeId])
  @@map("rates")
}

model ParkingArea {
  id            Int               @id @default(autoincrement())
  name          String
  vehicleTypeId Int               @map("vehicle_type_id")
  vehicleType   VehicleType       @relation(fields: [vehicleTypeId], references: [id], onDelete: Restrict)
  capacity      Int
  // occupied count is computed from open transactions
  location      String?
  status        ParkingAreaStatus @default(Open)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  transactions  Transaction[]

  @@index([vehicleTypeId])
  @@map("parking_areas")
}

model Transaction {
  id              Int               @id @default(autoincrement())
  attendantId     Int?              @map("attendant_id")
  attendant       User?             @relation("TransactionsAttendedBy", fields: [attendantId], references: [id], onDelete: SetNull)
  tagId           String?           @map("tag_id")
  areaId          Int               @map("area_id")
  parkingArea     ParkingArea       @relation(fields: [areaId], references: [id], onDelete: Restrict)
  rateId          Int?              @map("rate_id")
  rate            Rate?             @relation(fields: [rateId], references: [id], onDelete: SetNull)
  rateSnapshot    Json?             @map("rate_snapshot")
  entryTime       DateTime          @map("entry_time")
  exitTime        DateTime?         @map("exit_time")
  durationMinutes Int?              @map("duration_minutes")
  amountCents     Int?              @map("amount_cents")
  status          TransactionStatus @default(Open)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  payment  Payment?
  receipts Receipt[]

  @@index([areaId, status])
  @@index([attendantId])
  @@index([rateId])
  @@index([tagId, status])
  @@map("transactions")
}

model Payment {
  id                Int           @id @default(autoincrement())
  transactionId     Int           @unique @map("transaction_id")
  transaction       Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  paymentMethod     PaymentMethod @map("payment_method")
  status            PaymentStatus @default(Pending)
  providerReference String?       @map("provider_reference")
  processedAt       DateTime?     @map("processed_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  receipt Receipt?
  refund  Refund?

  @@map("payments")
}

model Receipt {
  id            Int         @id @default(autoincrement())
  transactionId Int         @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  paymentId     Int         @unique @map("payment_id")
  payment       Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  receiptData   Json        @map("receipt_data")
  printedById   Int?        @map("printed_by")
  printedBy     User?       @relation("ReceiptsPrintedBy", fields: [printedById], references: [id], onDelete: SetNull)
  printedAt     DateTime    @default(now()) @map("printed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([transactionId])
  @@index([printedById])
  @@map("receipts")
}

model Refund {
  id            Int      @id @default(autoincrement())
  paymentId     Int      @unique @map("payment_id")
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amountCents   Int      @map("amount_cents")
  reason        String
  processedById Int?     @map("processed_by")
  processedBy   User?    @relation("RefundsProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)
  processedAt   DateTime @default(now()) @map("processed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([processedById])
  @@map("refunds")
}